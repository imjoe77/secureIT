{
  "name": "multi-tenant-saas-permission-firewall",
  "version": "1.0.0",
  "description": "Multi-Tenant SaaS Permission Escalation Firewall - Real-time authorization system that prevents indirect privilege escalation",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:setup": "node src/database/setup.js",
    "db:seed": "node src/database/seed.js",
    "db:reset": "node src/database/setup.js && node src/database/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
